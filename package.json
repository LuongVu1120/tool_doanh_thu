{
  "name": "huyk-tools",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:api": "tsx apps/api/src/index.ts",
    "dev:worker": "tsx apps/worker/src/index.ts",
    "build": "next build",
    "build:web": "next build",
    "start": "next start",
    "start:web": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "type-check:api": "tsc -p apps/api/tsconfig.json --noEmit",
    "type-check:worker": "tsc -p apps/worker/tsconfig.json --noEmit",
    "type-check:packages": "tsc -p packages/shared/tsconfig.json --noEmit && tsc -p packages/db/tsconfig.json --noEmit",
    "test:parser": "tsx scripts/test-parser.ts",
    "test:revenue-golden": "tsx scripts/test-revenue-golden.ts",
    "seed:revenue-golden": "tsx scripts/seed-golden-adjustments.ts",
    "check:revenue-db": "tsx scripts/check-db-revenue-reconciliation.ts",
    "clear:revenue-data": "tsx scripts/clear-revenue-data.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^3",
    "@supabase/ssr": "^0.5",
    "@supabase/supabase-js": "^2",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3",
    "lucide-react": "^0.400.0",
    "next": "14.2.0",
    "next-themes": "^0.3.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7",
    "recharts": "^2",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "pg": "^8.21.0",
    "postcss": "^8",
    "tailwindcss": "^3",
    "tsx": "^4",
    "typescript": "^5"
  }
}
