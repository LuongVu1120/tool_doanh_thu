# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# Worker
WORKER_POLL_INTERVAL_MS=30000

# Anthropic (for chat feature)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Sapo connection (chọn 1 trong 2 cách auth)
SAPO_STORE=your-shop-name
# Cách 1 - Sapo Private App (Basic Auth, khuyến nghị cho shop nội bộ):
#   Vào Sapo admin > Ứng dụng > Ứng dụng riêng > Tạo ứng dụng riêng.
#   Sapo sẽ phát ra API Key + API Secret, paste vào dưới đây.
SAPO_API_KEY=your-sapo-api-key
SAPO_API_SECRET=your-sapo-api-secret
# Cách 2 - OAuth Custom App (X-Sapo-Access-Token header):
#   Bỏ qua nếu đã dùng Cách 1. Cách này dùng access token vĩnh viễn
#   lấy được sau OAuth flow.
SAPO_ACCESS_TOKEN=your-sapo-access-token
SAPO_SCOPES=read_orders
SAPO_WEBHOOK_SECRET=change-me
CRON_SECRET=change-me
